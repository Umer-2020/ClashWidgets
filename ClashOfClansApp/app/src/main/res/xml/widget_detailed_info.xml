<?xml version="1.0" encoding="utf-8"?>
<!--
    Detailed Widget – AppWidget provider metadata.
    4×4 grid cell target. Larger layout to show names + countdowns.
    updatePeriodMillis = 0 → updates are pushed by WidgetUpdateService.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="250dp"
    android:minResizeWidth="200dp"
    android:minResizeHeight="200dp"
    android:targetCellWidth="4"
    android:targetCellHeight="4"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_detailed"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_detailed_desc" />
