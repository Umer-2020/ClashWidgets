<?xml version="1.0" encoding="utf-8"?>
<!--
    Widget #2 – Detailed (4×4 / 5×4)
    FIX: All <View> elements replaced with <ImageView>.
    Plain <View> is NOT allowed in RemoteViews widget layouts.
    Allowed views: FrameLayout, LinearLayout, RelativeLayout, ImageView,
                   TextView, Button, Chronometer, ProgressBar, ImageButton.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_detailed_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="10dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚔ ClashyWidgets"
            android:textColor="#F0A500"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_detailed_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textColor="#7A6040"
            android:textSize="8sp" />
    </LinearLayout>

    <!-- HOME VILLAGE header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🏠 HOME VILLAGE"
        android:textColor="#F0A500"
        android:textSize="9sp"
        android:textStyle="bold"
        android:paddingTop="6dp"
        android:paddingBottom="1dp" />

    <!-- Builders label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👷 Builders"
        android:textColor="#D4B483"
        android:textSize="8sp"
        android:paddingTop="2dp"
        android:paddingBottom="1dp" />

    <!-- Builder Slot 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="1dp"
        android:paddingBottom="1dp">

        <!-- DOT: ImageView, not View -->
        <ImageView
            android:id="@+id/widget_detailed_hb1_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="#4CAF50"
            android:layout_marginEnd="4dp"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/widget_detailed_hb1_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Builder 1"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <Chronometer
            android:id="@+id/widget_detailed_hb1_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFD04B"
            android:textSize="8sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_detailed_hb1_finish"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available"
            android:textColor="#4CAF50"
            android:textSize="8sp" />
    </LinearLayout>

    <!-- Builder Slot 2 -->
