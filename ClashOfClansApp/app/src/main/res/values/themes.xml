<resources>

    <!--
        Base application theme.
        Inherits from Material3 DayNight to get baseline components,
        then overrides with CoC palette.
    -->
    <style name="Theme.ClashyWidgets" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary brand color (used by Material components) -->
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorPrimaryVariant">@color/gold_light</item>
        <item name="colorOnPrimary">@color/bg_dark</item>

        <!-- Secondary (elixir purple) -->
        <item name="colorSecondary">@color/elixir_purple</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <!-- Backgrounds -->
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar (system bar at the bottom) -->
        <item name="android:navigationBarColor">@color/nav_bar_bg</item>

    </style>

</resources>
